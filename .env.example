EXPO_PUBLIC_API_BASE_URL=https://nikesh2290-krishisaathi-backend.hf.space
EXPO_PUBLIC_USE_NATIVE_GEMMA=0
EXPO_PUBLIC_NATIVE_GEMMA_MODEL_PATH=

# Supabase — KrishiSaathi-AI (publishable/anon key only; never service_role in the app).
EXPO_PUBLIC_SUPABASE_URL=https://ivwnljoodlmpgbbfekdk.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=

# --- EAS builds (APK / IPA / AAB): `.env` is NOT bundled. expo.dev must supply secrets at build time.
# 1) Copy this file to `.env` and fill EXPO_PUBLIC_SUPABASE_KEY (anon key from Supabase Dashboard → Settings → API).
# 2) In Expo: Project → krishi-sathi-ai → Environment variables → add for Preview + Production:
#    EXPO_PUBLIC_SUPABASE_KEY = <same anon key> (mark Sensitive).
#    URL is also set in eas.json; override here if you use a different project.
# 3) Rebuild: npx eas-cli build --platform android --profile preview
# Google native sign-in needs EXPO_PUBLIC_GOOGLE_* in EAS as well if you use OAuth on device.

# --- Google Cloud (Web OAuth client) — paste into Authorized JavaScript origins / redirect URIs ---
# Origins:    https://ivwnljoodlmpgbbfekdk.supabase.co
# Redirect:   https://ivwnljoodlmpgbbfekdk.supabase.co/auth/v1/callback
# Full checklist: scripts/google-oauth-copy-paste.txt
# Doc: https://supabase.com/docs/guides/auth/social-login/auth-google?queryGroups=platform&platform=react-native
# Supabase → Auth → URL Configuration — add every redirect your app actually uses:
# - Expo web PKCE: http://localhost:8081/auth-callback (port may differ)
# - Dev / standalone native: krishisaathi://auth-callback
# - Expo Go native OAuth uses exp://… NOT your custom scheme — copy the exact URL from Metro:
#   search dev logs for "[OAuth] redirectTo" or run once and add e.g.
#   exp://127.0.0.1:8081/--/auth-callback
#   exp://192.168.x.x:8081/--/auth-callback   (LAN IP when testing on a physical device)

# Web OAuth client ID (required for native sign-in webClientId + Supabase provider; list first in Dashboard).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=fc6079c4-aad1-4ffd-b0aa-e26174ab8eca

# iOS only: REVERSED_CLIENT_ID / Expo plugin (com.googleusercontent.apps....)
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=

# iOS only: iOS OAuth client ID string from Google Cloud (optional but recommended).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=fc6079c4-aad1-4ffd-b0aa-e26174ab8eca
