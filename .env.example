EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8000
EXPO_PUBLIC_USE_NATIVE_GEMMA=
# Optional adb sideload (plain path, .litertlm). Example: /data/local/tmp/gemma-4-E2B-it.litertlm
EXPO_PUBLIC_NATIVE_GEMMA_MODEL_PATH=
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_KEY=

# Google OAuth — see scripts/google-oauth-copy-paste.txt
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# data.gov.in — Mandi (AGMARKNET) live daily price API
# Get a key at https://data.gov.in/user/register
EXPO_PUBLIC_DATA_GOV_API_KEY=your_data_gov_api_key_here
